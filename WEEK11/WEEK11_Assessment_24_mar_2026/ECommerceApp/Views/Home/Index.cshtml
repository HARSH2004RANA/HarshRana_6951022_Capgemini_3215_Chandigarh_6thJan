@{
    ViewData["Title"] = "Home";
}

<div class="container mt-5">

    <!-- 🔷 HERO SECTION -->
    <div class="text-center mb-5">
        <h1 class="display-4 fw-bold text-primary">🛒 E-Commerce Management System</h1>
        <p class="lead text-secondary">Manage Products, Orders, Customers & Categories easily</p>
    </div>

    <!-- 🔷 CARDS -->
    <div class="row g-4">

        <!-- PRODUCTS -->
        <div class="col-md-3">
            <div class="card shadow text-center border-0">
                <div class="card-body">
                    <h1 class="text-primary">🛍</h1>
                    <h5 class="card-title">Products</h5>
                    <p class="text-muted">Manage all products</p>
                    <a asp-controller="Products" asp-action="Index" class="btn btn-primary w-100">
                        Open
                    </a>
                </div>
            </div>
        </div>

        <!-- CATEGORIES -->
        <div class="col-md-3">
            <div class="card shadow text-center border-0">
                <div class="card-body">
                    <h1 class="text-success">📂</h1>
                    <h5 class="card-title">Categories</h5>
                    <p class="text-muted">Organize categories</p>
                    <a asp-controller="Categories" asp-action="Index" class="btn btn-success w-100">
                        Open
                    </a>
                </div>
            </div>
        </div>

        <!-- CUSTOMERS -->
        <div class="col-md-3">
            <div class="card shadow text-center border-0">
                <div class="card-body">
                    <h1 class="text-warning">👥</h1>
                    <h5 class="card-title">Customers</h5>
                    <p class="text-muted">Manage customers</p>
                    <a asp-controller="Customers" asp-action="Index" class="btn btn-warning w-100">
                        Open
                    </a>
                </div>
            </div>
        </div>

        <!-- ORDERS -->
        <div class="col-md-3">
            <div class="card shadow text-center border-0">
                <div class="card-body">
                    <h1 class="text-danger">📦</h1>
                    <h5 class="card-title">Orders</h5>
                    <p class="text-muted">Track orders</p>
                    <a asp-controller="Orders" asp-action="Index" class="btn btn-danger w-100">
                        Open
                    </a>
                </div>
            </div>
        </div>

    </div>

    <!-- 🔷 DASHBOARD BUTTON -->
    <div class="text-center mt-5">
        <a asp-controller="Admin" asp-action="Dashboard" class="btn btn-dark btn-lg px-5">
            📊 Go to Dashboard
        </a>
    </div>

</div>