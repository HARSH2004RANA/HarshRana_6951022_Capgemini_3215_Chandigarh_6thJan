@model ECommerceApp.Models.Order

<h2>Order Details</h2>

<p><strong>Order Date:</strong> @Model.OrderDate</p>
<p><strong>Customer:</strong> @Model.Customer?.Email</p>
<p><strong>Shipping Status:</strong> @Model.ShippingDetail?.Status</p>

<hr />

<h4>Products</h4>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>Product</th>
            <th>Quantity</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var item in Model.OrderItems)
        {
            <tr>
                <td>@item.Product?.Name</td>
                <td>@item.Quantity</td>
            </tr>
        }
    </tbody>
</table>

<a asp-action="Index" class="btn btn-secondary">Back</a>