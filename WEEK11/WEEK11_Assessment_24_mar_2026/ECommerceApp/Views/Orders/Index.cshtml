@model IEnumerable<ECommerceApp.Models.Order>

@{
    ViewData["Title"] = "Orders";
}

<h2 class="mb-3">📦 Orders</h2>

<!-- ➕ CREATE BUTTON -->
<a asp-action="Create" class="btn btn-success mb-3">
    + Create Order
</a>

<!-- 📊 ORDERS TABLE -->
<table class="table table-hover table-striped shadow">
    <thead class="table-dark">
        <tr>
            <th>Order ID</th>
            <th>Date</th>
            <th>Customer</th>
            <th>Status</th>
            <th style="width:220px;">Actions</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td><strong>#@item.OrderId</strong></td>

                <td>@item.OrderDate.ToShortDateString()</td>

                <td>@item.Customer?.Email</td>

                <!-- 🔥 SHIPPING STATUS -->
                <td>
                    <span class="badge bg-secondary">
                        @(item.ShippingDetail?.Status ?? "N/A")
                    </span>
                </td>

                <!-- 🔥 ACTION BUTTONS -->
                <td>
                    <a asp-action="Details" asp-route-id="@item.OrderId"
                       class="btn btn-info btn-sm">View</a>

                    <a asp-action="Edit" asp-route-id="@item.OrderId"
                       class="btn btn-warning btn-sm">Edit</a>

                    <a asp-action="Delete" asp-route-id="@item.OrderId"
                       class="btn btn-danger btn-sm">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>