@page
@model DashboardModel
@{
    ViewData["Title"] = "Dashboard";
}

<div class="container py-4">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-start gap-3 mb-4">
        <div>
            <p class="eyebrow text-uppercase mb-2">Dashboard</p>
            <h1 class="fw-bold">Your event schedule</h1>
            <p class="text-secondary">Browse upcoming events, choose a seat, and confirm your booking with one click.</p>
        </div>
        <a class="btn btn-outline-secondary" href="/">Sign Out</a>
    </div>

    <div class="row g-3 mb-5">
        <div class="col-md-4">
            <div class="card summary-card shadow-sm p-4">
                <p class="text-uppercase text-muted mb-2">Total Events</p>
                <h2 id="totalEvents" class="fw-bold">0</h2>
                <p class="text-muted">Events open for booking.</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card summary-card shadow-sm p-4">
                <p class="text-uppercase text-muted mb-2">Available Seats</p>
                <h2 id="totalSeats" class="fw-bold">0</h2>
                <p class="text-muted">Seats currently unreserved.</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card summary-card shadow-sm p-4">
                <p class="text-uppercase text-muted mb-2">Selected Event</p>
                <h2 id="selectedEventName" class="fw-bold">None</h2>
                <p class="text-muted">Pick an event from the list.</p>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-xl-8">
            <section class="mb-4">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h2 class="h5 mb-0">Upcoming events</h2>
                    <span class="text-muted" id="eventCountLabel">0 events found</span>
                </div>
                <div class="table-responsive shadow-sm rounded overflow-hidden bg-white">
                    <table class="table mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>ID</th>
                                <th>Title</th>
                                <th>Date</th>
                                <th>Location</th>
                                <th>Seats</th>
                                <th>Action</th>
                            </tr>
                        </thead>
                        <tbody id="eventTable"></tbody>
                    </table>
                </div>
            </section>

            <section>
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h2 class="h5 mb-0">Event highlights</h2>
                    <span class="text-muted">Browse cards for quick details</span>
                </div>
                <div class="row row-cols-1 row-cols-md-2 g-3" id="eventCards"></div>
            </section>
        </div>

        <div class="col-xl-4">
            <div class="card booking-card shadow-sm p-4">
                <div class="mb-4">
                    <p class="text-uppercase text-muted mb-2">Booking</p>
                    <h3 class="fw-bold">Reserve your seat</h3>
                </div>

                <div class="mb-3">
                    <label class="form-label text-muted">Selected Event</label>
                    <input id="eventTitle" class="form-control" disabled placeholder="Select an event first" />
                </div>

                <div class="mb-3">
                    <input id="eventId" type="number" class="form-control" placeholder="Event ID" readonly />
                </div>
                <div class="mb-3">
                    <label class="form-label text-muted">Seats to book</label>
                    <input id="seats" type="number" class="form-control" placeholder="Enter seats" min="1" />
                </div>
                <div class="mb-3 text-muted small">
                    Click any <strong>Book</strong> button in the event list to prefill the booking form.
                </div>
                <button class="btn btn-gradient btn-lg w-100" onclick="bookEvent()">Confirm Booking</button>
                <div id="result" class="mt-4"></div>
            </div>
        </div>
    </div>
</div>