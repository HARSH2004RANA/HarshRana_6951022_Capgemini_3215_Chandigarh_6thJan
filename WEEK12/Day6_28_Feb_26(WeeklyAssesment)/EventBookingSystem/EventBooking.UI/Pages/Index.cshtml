@page
@model IndexModel
@{
    ViewData["Title"] = "Login";
}

<section class="page-hero py-5">
    <div class="container">
        <div class="row align-items-center gy-4">
            <div class="col-lg-6 text-center text-lg-start">
                <p class="eyebrow text-uppercase mb-2">Welcome back</p>
                <h1 class="display-5 fw-bold">Secure event booking for your next experience.</h1>
                <p class="lead text-secondary mt-3">Login to manage your seat reservations, view upcoming events, and book instantly with a seamless dashboard.</p>
            </div>
            <div class="col-lg-5 offset-lg-1">
                <div class="card login-card shadow-lg p-4">
                    <div class="mb-4 text-center">
                        <h4 class="fw-bold mb-1">Member Login</h4>
                        <p class="text-muted mb-0">Use admin@gmail.com / 123 to try it.</p>
                    </div>

                    <div class="mb-3">
                        <label class="form-label small text-uppercase text-muted">Email</label>
                        <input id="email" class="form-control form-control-lg" placeholder="admin@gmail.com" />
                    </div>
                    <div class="mb-4">
                        <label class="form-label small text-uppercase text-muted">Password</label>
                        <input id="password" type="password" class="form-control form-control-lg" placeholder="Enter password" />
                    </div>

                    <button class="btn btn-primary btn-lg w-100" onclick="login()">Login to Dashboard</button>
                </div>
            </div>
        </div>
    </div>
</section>